    ".": {
      "release-type": "maven",
      "package-name": "scribejava",
      "changelog-path": "CHANGELOG.md"
    },
    "scribejava-core": { "release-type": "maven", "package-name": "scribejava-core" },
    "scribejava-oidc": { "release-type": "maven", "package-name": "scribejava-oidc" },
    "scribejava-apis": { "release-type": "maven", "package-name": "scribejava-apis" },
    "scribejava-oauth1": { "release-type": "maven", "package-name": "scribejava-oauth1" },
    "scribejava-httpclient-okhttp": { "release-type": "maven", "package-name": "scribejava-httpclient-okhttp" },
    "scribejava-httpclient-armeria": { "release-type": "maven", "package-name": "scribejava-httpclient-armeria" },
    "scribejava-integration-helpers": { "release-type": "maven", "package-name": "scribejava-integration-helpers" }
