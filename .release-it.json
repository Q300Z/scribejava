{
  "git": {
    "commitMessage": "chore(release): ${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true,
    "requireBranch": "master",
    "push": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "assets": ["target/release-artifacts/*.jar"],
    "comments": {
      "submit": true,
      "issue": "🚀 Version ${version} certifiée multi-JDK et publiée."
    }
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": "mvn versions:set -DnewVersion=${version} -DgenerateBackupPoms=false && mvn versions:commit",
    "before:github:release": "mvn clean package -Prelease-package -DskipTests -Dmaven.javadoc.skip=true -Dspotless.check.skip=true -Dcheckstyle.skip=true -Dpmd.skip=true -Dlicense.skip=true"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md",
      "header": "# 📓 Journal des modifications (Changelog)"
    }
  }
}
